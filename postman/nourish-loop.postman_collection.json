{
  "info": {
    "name": "Nourish-Loop API",
    "_postman_id": "a1b2c3d4-0000-4000-8000-nourishloop01",
    "description": "Bộ request test cho backend Nourish-Loop (Food Life).\n\nYêu cầu trước khi chạy:\n1. `npx prisma db push` rồi `npx prisma db seed`\n2. `npm run start:dev`\n3. Chọn environment \"Nourish-Loop Local\".\n\nMật khẩu mọi tài khoản seed: 123456.\nMột số request có test-script tự lưu biến (userId, providerId, postId) để dùng cho request sau.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('status = ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register (tài khoản mới)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@test.vn\",\n  \"password\": \"123456\",\n  \"fullName\": \"Người Mới\",\n  \"role\": \"RECEIVER\",\n  \"org\": \"NGO Test\",\n  \"phone\": \"0903000000\",\n  \"address\": \"Quận 7, TP.HCM\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "Đăng ký tài khoản mới. Dùng email đã tồn tại (seed) sẽ trả 409."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Tạo thành công (201) hoặc trùng email (409)', () => pm.expect([201, 409]).to.include(pm.response.code));",
                  "if (pm.response.code === 201) {",
                  "  const u = pm.response.json();",
                  "  pm.test('không trả passwordHash', () => pm.expect(u).to.not.have.property('passwordHash'));",
                  "  pm.collectionVariables.set('userId', u.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login (Receiver - Hoa Sen)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lan@bepanhoasen.vn\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Đăng nhập OK', () => pm.expect([200, 201]).to.include(pm.response.code));",
                  "const body = pm.response.json();",
                  "pm.test('có sessionToken', () => pm.expect(body).to.have.property('sessionToken'));",
                  "pm.test('đúng vai trò RECEIVER', () => pm.expect(body.user.role).to.eql('RECEIVER'));",
                  "pm.collectionVariables.set('token', body.sessionToken);",
                  "pm.collectionVariables.set('receiverId', body.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login (Provider - Lotus)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"minhanh@lotussaigon.vn\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Lưu id của provider vào biến providerId để dùng cho 'Create Post'."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Đăng nhập OK', () => pm.expect([200, 201]).to.include(pm.response.code));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('token', body.sessionToken);",
                  "pm.collectionVariables.set('providerId', body.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/login (SAI mật khẩu - kỳ vọng 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"lan@bepanhoasen.vn\",\n  \"password\": \"sai-mat-khau\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Trả 401 Unauthorized', () => pm.response.to.have.status(401));"]
              }
            }
          ]
        },
        {
          "name": "GET /auth/me (cần token)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] },
            "description": "Lấy user hiện tại từ session token. Chạy SAU một request Login."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('trả đúng user', () => pm.expect(pm.response.json()).to.have.property('email'));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "description": "Đăng xuất: xoá session. Sau bước này, GET /auth/me với token cũ sẽ trả 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('success = true', () => pm.expect(pm.response.json().success).to.eql(true));"
                ]
              }
            }
          ]
        }
      ]
    },
