# ============================================================
# Nourish-Loop Backend - Environment Variables
# Sao chép file này thành .env và điền giá trị thật.
# ============================================================

# Postgres connection string.
# Local:  postgresql://postgres:postgres@localhost:5432/nourish_loop?schema=public
# Render: lấy "Internal Database URL" từ Render Postgres dashboard.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nourish_loop?schema=public"

# JWT
JWT_SECRET="thay-bang-chuoi-bi-mat-dai-ngau-nhien"
JWT_EXPIRES_IN="7d"

# HTTP server (Render tự inject PORT; local mặc định 3000)
PORT=3000

# CORS: origin của frontend nourish-loop (vd http://localhost:3000 hoặc URL Lovable/Render của FE)
CORS_ORIGIN="http://localhost:5173"
